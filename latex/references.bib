@article{clarkRealTimeDensityForecasts2011,
	title = {Real-{Time} {Density} {Forecasts} {From} {Bayesian} {Vector} {Autoregressions} {With} {Stochastic} {Volatility}},
	volume = {29},
	issn = {0735-0015, 1537-2707},
	url = {http://www.tandfonline.com/doi/abs/10.1198/jbes.2010.09248},
	doi = {10.1198/jbes.2010.09248},
	abstract = {Central banks and other forecasters are increasingly interested in various aspects of density forecasts. However, recent sharp changes in macroeconomic volatility, including the Great Moderation and the more recent sharp rise in volatility associated with increased variation in energy prices and the deep global recession—pose significant challenges to density forecasting. Accordingly, this paper examines, with real time data, density forecasts of U.S. GDP growth, unemployment, inflation, and the federal funds rate from Bayesian vector autoregression (BVAR) models with stochastic volatility. The results indicate that adding stochastic volatility to BVARs materially improves the real-time accuracy of density forecasts. This article has supplementary material},
	language = {en},
	number = {3},
	urldate = {2026-02-24},
	journal = {Journal of Business \& Economic Statistics},
	author = {Clark, Todd E.},
	month = jul,
	year = {2011},
	pages = {327--341},
	annote = {Annotations(3/4/2026, 12:11:43 PM)


Forecast US macro variables with BVARs that allow for stochastic volatility. 


Forecat GDP growth, unemployment, inflation, and fed funds rate.


Accuracy of point forecasts is improved by specifying infation and interest rates as deviations from trend inflation according to Clark and McCracken (2008, 2010).


Other literature has shown use of a prior on the steady state improves accuracy of point forecasts (Adolfson et al. 2007; Osterholm 2008; Wright 2010). 


Could this be connected to the idea that information about the distribution of a variable improves point forecasts as in Andrade et al (2012)?




Adding stochastic volatility to BVAR improves real-time density forecasts and point forecasts.


BVAR first requires parametric assumptions and cannot handle big data.


“Over time, then, obtaingin reliable density forecasts likely requires forecast methods that allow for repeated breaks in volatilities” (Clark, 2011, p. 327)
“. Results reported by Jore, Mitchell, and Vahey (2010) support this intuition. In an analysis of real-time density forecasts since the mid-1980s, those authors found that models estimated with full samples of data and constant parameters fared poorly in density forecast ing. Allowing discrete breaks in variances materially improved density forecasts made in the Great Moderation per” (Clark, 2011, p. 327) Supports evidence of time-varying densities
},
	file = {PDF:/home/rproner/Zotero/storage/P5TDZK6B/Clark - 2011 - Real-Time Density Forecasts From Bayesian Vector Autoregressions With Stochastic Volatility.pdf:application/pdf},
}

@article{adrianVulnerableGrowth2019,
